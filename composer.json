{
    "name": "jayeshmepani/panchang-core",
    "description": "Authentic Vedic Panchanga calculation engine with Swiss Ephemeris precision",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "keywords": [
        "panchang",
        "vedic",
        "astrology",
        "jyotish",
        "tithi",
        "nakshatra",
        "muhurta",
        "festival",
        "hindu calendar",
        "swiss ephemeris"
    ],
    "authors": [
        {
            "name": "Jayesh Patel",
            "email": "jayeshmepani777@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "jayeshmepani/swiss-ephemeris-ffi": "^1.1",
        "nesbot/carbon": "^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "JayeshMepani\\PanchangCore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JayeshMepani\\PanchangCore\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --do-not-fail-on-warning --do-not-fail-on-phpunit-warning --do-not-fail-on-incomplete --do-not-fail-on-deprecation --do-not-fail-on-phpunit-deprecation",
        "rector": "vendor/bin/rector process",
        "lint": "pint",
        "lint:fix": "pint",
        "lint:check": "pint --test",
        "test:lint": "@lint:check",
        "phpstan": "phpstan analyse --memory-limit=2G",
        "rector:dry": "rector process --dry-run",
        "quality": [
            "@lint:check",
            "@phpstan",
            "@test"
        ]
    },
    "conflict": {
        "php": "<8.3"
    },
    "extra": {
        "laravel": {
            "providers": [
                "JayeshMepani\\PanchangCore\\PanchangServiceProvider"
            ],
            "aliases": {
                "Panchang": "JayeshMepani\\PanchangCore\\Facades\\Panchang"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.3.0"
        },
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    }
}
