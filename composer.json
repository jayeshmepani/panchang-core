{
    "name": "jayeshmepani/panchang-core",
    "description": "Authentic Vedic Panchanga calculation engine with Swiss Ephemeris precision",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "panchang",
        "vedic",
        "astrology",
        "jyotish",
        "tithi",
        "nakshatra",
        "muhurta",
        "festival",
        "hindu calendar",
        "swiss ephemeris"
    ],
    "authors": [
        {
            "name": "Jayesh Patel",
            "email": "jayeshmepani777@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "nesbot/carbon": "^3.0",
        "jayeshmepani/swiss-ephemeris-ffi": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0",
        "rector/rector": "^1.0",
        "orchestra/testbench": "^9.0 || ^10.0",
        "laravel/pint": "^1.13",
        "nunomaduro/collision": "^8.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "JayeshMepani\\PanchangCore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JayeshMepani\\PanchangCore\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --do-not-fail-on-warning --do-not-fail-on-phpunit-warning --do-not-fail-on-incomplete --do-not-fail-on-deprecation --do-not-fail-on-phpunit-deprecation",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=512M",
        "rector": "vendor/bin/rector process src",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes",

        "lint": "vendor/bin/pint",
        "lint:check": "vendor/bin/pint --test",

        "quality": [
            "@lint:check",
            "@phpstan",
            "@test"
        ]
    },
    "conflict": {
        "php": "<8.3"
    },
    "extra": {
        "laravel": {
            "providers": [
                "JayeshMepani\\PanchangCore\\PanchangServiceProvider"
            ],
            "aliases": {
                "Panchang": "JayeshMepani\\PanchangCore\\Facades\\Panchang"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.3.0"
        },
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
